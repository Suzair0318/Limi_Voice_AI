# Copy this file to `.env` and fill in your real credentials.
# Never commit your actual API key to source control.

OPENAI_API_KEY=sk-your-openai-api-key-here

# --- Optional overrides (defaults are defined in app/config.py) ---
# "gpt-4o-audio-preview" is retired; use the GA model "gpt-audio" (default)
# or "gpt-audio-mini" for lower cost.
# OPENAI_MODEL=gpt-audio
# OPENAI_VOICE=alloy

# Inbound audio format from the hardware board.
# INPUT_SAMPLE_RATE=16000
# INPUT_CHANNELS=1
# INPUT_SAMPLE_WIDTH=2

# Outbound audio format streamed back to the device.
# OUTPUT_SAMPLE_RATE=48000
# OUTPUT_CHANNELS=2

# Voice Activity Detection tuning.
# VAD_SILENCE_THRESHOLD=500.0
# VAD_SILENCE_DURATION=1.5
# VAD_MIN_SPEECH_DURATION=0.3

# Outbound streaming pacing.
# OUTPUT_CHUNK_MS=20
