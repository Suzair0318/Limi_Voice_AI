# Copy this file to `.env` and fill in your real credentials.
# Never commit your actual API key to source control.

OPENAI_API_KEY=sk-your-openai-api-key-here

# --- OpenAI Realtime model (defaults are defined in app/config.py) ---
# GA speech-to-speech model. Use a pinned date for stability if you like.
# OPENAI_REALTIME_MODEL=gpt-realtime
# OPENAI_VOICE=alloy
# System prompt / personality for the assistant.
# REALTIME_INSTRUCTIONS=You are Limi, a friendly, concise voice assistant...

# --- Turn detection (handled by OpenAI's server-side VAD) ---
# "server_vad" (silence-based) or "semantic_vad" (the model decides).
# REALTIME_VAD_TYPE=server_vad
# For server_vad: ms of trailing silence before a turn is considered over.
# REALTIME_SILENCE_MS=500
# Sample rate we send to the Realtime API (the device audio is resampled to it).
# REALTIME_INPUT_RATE=24000

# Inbound audio format from the hardware board.
# INPUT_SAMPLE_RATE=16000
# INPUT_CHANNELS=1
# INPUT_SAMPLE_WIDTH=2

# Outbound audio format streamed back to the device (must match firmware / ws_server.py).
# OUTPUT_SAMPLE_RATE=48000
# OUTPUT_CHANNELS=2
# Plain 16-bit stereo s16le over WebSocket (same as ws_server.py). Use 32 only if firmware asks.
# OUTPUT_I2S_SLOT_BITS=16
# Paced frame size — 3840 B = 20 ms @ 48 kHz stereo s16le; must stay under 8192 B firmware limit.
# OUTPUT_CHUNK_MS=20
# OUTPUT_MAX_WS_BYTES=3840

# Mic: 8-channel interleaved from 4 PDM lines x 2 slots. Try channel 0 if average is too quiet.
# INPUT_MIC_CHANNEL=0

# Mic-activity meter (display only): RMS above this logs a frame as "SPEAKING".
# This does NOT affect turn-taking anymore (the OpenAI server VAD does that).
# VAD_SILENCE_THRESHOLD=500.0
