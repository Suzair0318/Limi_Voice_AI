# Copy this file to `.env` and fill in your real credentials.

OPENAI_API_KEY=sk-your-openai-api-key-here

# MongoDB
MONGO_URL=mongodb://127.0.0.1:27017/limi_project_dev

# --- OpenAI Realtime ---
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_VOICE=alloy
REALTIME_INPUT_RATE=24000
REALTIME_OUTPUT_RATE=24000
REALTIME_VAD_TYPE=server_vad
REALTIME_SILENCE_MS=650
# REALTIME_INSTRUCTIONS=You are Limi, a concise friendly voice assistant.

# --- Device audio (stable hardware pipeline) ---
DEVICE_INPUT_RATE=16000
DEVICE_INPUT_CHANNELS=1
DEVICE_OUTPUT_RATE=24000
DEVICE_OUTPUT_CHANNELS=1
DEVICE_OUTPUT_CHUNK_MS=80
DEVICE_OUTPUT_INITIAL_BURST_CHUNKS=16
DEVICE_SEND_QUEUE_CHUNKS=2048
DEVICE_BUFFER_RESPONSE_AUDIO=true
SAVE_BACKEND_MIC=true
BACKEND_MIC_RECORDINGS_DIR=backend_mic_recordings
